@model IEnumerable<RappiDozApp.Models.Usuario>

<div class="gestion-usuarios">
    <div class="seccion-header">
        <h2 class="usuarios-title">Usuarios del Sistema</h2>
        <button onclick="abrirForm('Usuario', 'Crear')" class="btn-circular shadow">
            <i class="fa-solid fa-plus"></i>
        </button>
    </div>

    <div class="user-list">
        @foreach (var item in Model)
        {
            @* RESTAURADA LA CLASE user-card PARA EL DISEÑO DE CARTITA *@
            <div class="user-card animate__animated animate__fadeIn">

                @* LADO IZQUIERDO: Información del usuario *@
                <div class="user-info">
                    <div class="user-avatar">
                        @if (item.ContentType != null)
                        {
                            <img src="/Usuarios/Foto/@item.Id" alt="Avatar" loading="lazy" />
                        }
                        else
                        {
                            @* MOSTRAMOS LA INICIAL (Tus estilos originales) *@
                            <span>@item.NombreCompleto.Substring(0, 1).ToUpper()</span>
                        }
                    </div>

                    <div class="user-details">
                        @* Título e Email (Tus estilos originales) *@
                        <h3>
                            @item.NombreCompleto
                            <span class="badge-rol">@item.Rol?.NombreRol</span>
                        </h3>
                        <p><i class="fa-solid fa-envelope me-2"></i>@item.Email</p>
                    </div>
                </div>

                @* LADO DERECHO: Acciones (Tus estilos originales) *@
                <div class="acciones-der">
                    <button onclick="abrirForm('Usuario', 'Editar', @item.Id)" class="btn-accion edit" title="Editar">
                        <i class="fas fa-pencil-alt"></i>
                    </button>
                    <button onclick="eliminarRegistro('Usuario', @item.Id)" class="btn-accion delete" title="Eliminar">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>