@model IEnumerable<RappiDozApp.Models.Usuario>

<style>
    /* ============================================================
           1. TUS ESTILOS ORIGINALES (RESTAURADOS AL 100%)
           ============================================================ */
    .gestion-usuarios {
        animation: fadeInUp 0.5s ease;
        padding: 10px;
    }

    .seccion-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #f0e1cf;
        padding-bottom: 15px;
        margin-bottom: 30px;
    }

    /* Estilo de las Tarjetas (Cartitas) */
    .user-card {
        background: white;
        border-radius: 20px;
        padding: 15px 25px;
        display: flex;
        align-items: center;
        justify-content: space-between; /* Esto mantiene info a la izq y botones a la der */
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-bottom: 15px;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

        .user-card:hover {
            transform: translateX(8px);
            border-color: #d3ab80;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    /* Avatar e Información */
    .user-info {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    /* EL AVATAR: Combinación de tu estilo y soporte para imagen */
    .user-avatar {
        width: 55px;
        height: 55px;
        background: #472825; /* Color café de RappiDoz */
        color: #d3ab80; /* Color dorado */
        border-radius: 50%;
        display: flex; /* Flex para centrar imagen o texto */
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.4rem;
        box-shadow: 0 4px 10px rgba(71, 40, 37, 0.2);
        overflow: hidden; /* Importante para la foto circular */
        border: 2px solid #fdf2e2; /* Borde sutil */
    }

        /* Estilo específico para la imagen dentro del avatar */
        .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Mantiene la proporción */
        }

    .user-details h3 {
        margin: 0;
        color: #472825;
        font-size: 1.2rem;
        font-weight: 700;
    }

    .user-details p {
        margin: 0;
        color: #888;
        font-size: 0.9rem;
    }

    .badge-rol {
        background: #fdf2e2;
        color: #d3ab80;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-left: 10px;
    }

    /* Botones de Acción */
    .acciones-der {
        display: flex;
        gap: 12px;
    }

    .btn-accion {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
        border: none;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-accion.edit {
            background: #fdf2e2;
            color: #d3ab80;
        }

        .btn-accion.delete {
            background: #ffebeb;
            color: #ff4d4d;
        }

        .btn-accion:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-circular {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        border: none;
        background: #472825;
        color: white;
        transition: 0.3s;
    }

        .btn-circular:hover {
            transform: scale(1.1) rotate(90deg);
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="gestion-usuarios">
    <div class="seccion-header">
        <h2 style="color: #472825; font-weight: 800; margin: 0;">Usuarios del Sistema</h2>
        <button onclick="abrirForm('Usuario', 'Crear')" class="btn-circular shadow">
            <i class="fa-solid fa-plus"></i>
        </button>
    </div>

    <div class="user-list">
        @foreach (var item in Model)
        {
            @* RESTAURADA LA CLASE user-card PARA EL DISEÑO DE CARTITA *@
            <div class="user-card animate__animated animate__fadeIn">

                @* LADO IZQUIERDO: Información del usuario *@
                <div class="user-info">
                    <div class="user-avatar">
                        @if (item.FotoBinaria != null && item.FotoBinaria.Length > 0)
                        {
                            @* MOSTRAMOS FOTO REAL *@
                            var base64 = Convert.ToBase64String(item.FotoBinaria);
                            var imgSrc = $"data:{item.ContentType ?? "image/png"};base64,{base64}";
                            <img src="@imgSrc" alt="Avatar" />
                        }
                        else
                        {
                            @* MOSTRAMOS LA INICIAL (Tus estilos originales) *@
                            <span>@item.NombreCompleto.Substring(0, 1).ToUpper()</span>
                        }
                    </div>

                    <div class="user-details">
                        @* Título e Email (Tus estilos originales) *@
                        <h3>
                            @item.NombreCompleto
                            <span class="badge-rol">@item.Rol?.NombreRol</span>
                        </h3>
                        <p><i class="fa-solid fa-envelope me-2"></i>@item.Email</p>
                    </div>
                </div>

                @* LADO DERECHO: Acciones (Tus estilos originales) *@
                <div class="acciones-der">
                    <button onclick="abrirForm('Usuario', 'Editar', @item.Id)" class="btn-accion edit" title="Editar">
                        <i class="fas fa-pencil-alt"></i>
                    </button>
                    <button onclick="eliminarRegistro('Usuario', @item.Id)" class="btn-accion delete" title="Eliminar">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>