@model RappiDozApp.Models.Producto

<div class="p-4">
    <form id="formProducto" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-md-5 text-center">
                <label class="form-label d-block mb-3 fw-bold" style="color: #472825;">Imagen del Platillo</label>
                <div class="image-preview-container" style="position: relative; display: inline-block;">
                    <img id="previewFoto"
                         src="@(Model.FotoBinaria != null ? $"data:{Model.ContentType};base64,{Convert.ToBase64String(Model.FotoBinaria)}" : "/img/placeholder-food.png")"
                         style="width: 200px; height: 200px; object-fit: cover; border-radius: 25px; border: 3px solid #f0e1cf; box-shadow: 0 10px 20px rgba(0,0,0,0.05);" />

                    <input type="file" name="fotoArchivo" id="fotoArchivo" class="d-none" accept="image/*" onchange="previewImage(this)" />

                    <button type="button" class="btn"
                            style="position: absolute; bottom: 15px; right: 15px; background: #472825; color: white; border-radius: 50%; width: 45px; height: 45px;"
                            onclick="document.getElementById('fotoArchivo').click()">
                        <i class="fas fa-camera"></i>
                    </button>
                </div>
            </div>

            <div class="col-md-7">
                <div class="mb-3">
                    <label class="form-label fw-bold">Nombre del Platillo</label>
                    <input asp-for="Nombre" class="form-control rd-input" placeholder="Nombre delicioso..." required />
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold">Precio (₡)</label>
                        <input asp-for="Precio" type="number" class="form-control rd-input" placeholder="0" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold">Categoría</label>
                        <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-select rd-input">
                            <option value="">Seleccionar...</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Restaurante</label>
                    <select asp-for="RestauranteId" asp-items="ViewBag.Restaurantes" class="form-select rd-input"></select>
                </div>
            </div>

            <div class="col-12">
                <label class="form-label fw-bold">Descripción Corta</label>
                <textarea asp-for="Descripcion" class="form-control rd-input" rows="3" placeholder="Ingredientes, detalles..."></textarea>
            </div>
        </div>

        <div class="row mt-5 pt-3 border-top">
            <div class="col-12 text-end">
                <button type="button" class="btn btn-light px-4 me-2" style="border-radius:12px;" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" onclick="guardarDatos('Producto')" class="btn px-5"
                        style="background: #472825; color: white; border-radius: 12px; font-weight: bold;">
                    Guardar Platillo
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) { document.getElementById('previewFoto').src = e.target.result; };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>