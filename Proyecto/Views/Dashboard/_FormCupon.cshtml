@model RappiDozApp.Models.Cupon

<style>
    /* Contenedor con espacio para que no pegue a los bordes */
    .form-gold-wrapper {
        padding: 35px;
        color: #472825;
    }

    .form-main-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 40px;
        align-items: center;
    }

    /* Formulario */
    .input-group {
        margin-bottom: 18px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .input-group label {
            font-size: 0.8rem;
            font-weight: 800;
            text-transform: uppercase;
            color: #472825;
        }

    .gold-input {
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 0.9rem;
        background: #fff;
    }

    .input-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    /* --- ÁREA DE PREVISUALIZACIÓN --- */
    .preview-aside {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .preview-label {
        font-size: 0.7rem;
        font-weight: bold;
        color: #d3ab80;
        letter-spacing: 2px;
        margin-bottom: 20px;
    }

    /* El Círculo de Visualización */
    .preview-circle {
        width: 260px;
        height: 260px;
        border: 2px dashed #d3ab80;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fdfaf6;
    }

    /* Cupón Horizontal Minimalista (Un solo color) */
    .minimal-coupon {
        width: 200px;
        height: 100px;
        background: #472825; /* Un solo color para notar las muescas */
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

        /* Muescas laterales */
        .minimal-coupon::before, .minimal-coupon::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            background: #fdfaf6; /* Color igual al fondo del círculo */
            border-radius: 50%;
            top: 50%;
            transform: translateY(-50%);
        }

        .minimal-coupon::before {
            left: -10px;
        }

        .minimal-coupon::after {
            right: -10px;
        }

    /* Texto del descuento (Solo esto dentro) */
    #bD {
        color: #d3ab80;
        font-size: 2.5rem;
        font-weight: 900;
        margin: 0;
    }

    /* Footer */
    .form-actions {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 15px;
    }
</style>

<div class="form-gold-wrapper fade-in">
    <form id="formCupon" autocomplete="off">
        <input type="hidden" asp-for="Id" />

        <div class="form-main-grid">

            @* COLUMNA IZQUIERDA: FORMULARIO *@
            <div class="form-col">
                <div class="input-group">
                    <label>Título del Cupón</label>
                    <input asp-for="Titulo" class="gold-input" placeholder="Ej. 25% RappiDoz">
                </div>

                <div class="input-group">
                    <label>Descripción Corta</label>
                    <input asp-for="Descripcion" class="gold-input" placeholder="Válido en...">
                </div>

                <div class="input-group">
                    <label>Categoría</label>
                    <select asp-for="CategoriaId" class="gold-input" asp-items="@(ViewBag.Categorias as List<SelectListItem>)">
                        <option value="">-- Todo el Menú --</option>
                    </select>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Código</label>
                        <input asp-for="Codigo" class="gold-input" style="text-transform:uppercase">
                    </div>
                    <div class="input-group">
                        <label>Expiración</label>
                        <input type="date" name="FechaExpiracion" class="gold-input" value="@(Model.FechaExpiracion?.ToString("yyyy-MM-dd"))">
                    </div>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Valor</label>
                        <input asp-for="Descuento" id="vD" type="number" step="0.01" class="gold-input">
                    </div>
                    <div class="input-group">
                        <label>Tipo</label>
                        <select asp-for="EsPorcentaje" id="tD" class="gold-input">
                            <option value="true">Porcentaje (%)</option>
                            <option value="false">Monto Fijo (₡)</option>
                        </select>
                    </div>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Stock</label>
                        <input asp-for="Stock" type="number" class="gold-input">
                    </div>
                    <div class="input-group" style="flex-direction:row; align-items:center; gap:10px; padding-top:25px;">
                        <input type="checkbox" asp-for="Activo" style="width:18px; height:18px; accent-color:#472825;">
                        <label style="margin:0; font-weight:bold;">Activo</label>
                    </div>
                </div>
            </div>

            @* COLUMNA DERECHA: CÍRCULO CON CUPÓN *@
            <div class="preview-aside">
                <span class="preview-label">PREVISUALIZACIÓN</span>
                <div class="preview-circle">
                    <div class="minimal-coupon">
                        <h1 id="bD">@Model.Descuento@(Model.EsPorcentaje ? "%" : "₡")</h1>
                    </div>
                </div>
            </div>

        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-link" data-bs-dismiss="modal" style="color:#999; text-decoration:none; font-weight:bold;">Cerrar</button>
            <button type="button" onclick="guardarDatos('Cupon')"
                    style="background:#472825; color:#d3ab80; padding:12px 25px; border:none; border-radius:8px; font-weight:bold; cursor:pointer;">
                Aplicar Cambios
            </button>
        </div>
    </form>
</div>

<script>
    (function() {
        const v = document.getElementById('vD'),
              t = document.getElementById('tD'),
              b = document.getElementById('bD');

        const upd = () => {
            const val = v.value || '0';
            const simbolo = (t.value === 'true' || t.value === 'True') ? '%' : '₡';
            b.innerText = `${val}${simbolo}`;
        };

        v.oninput = upd;
        t.onchange = upd;
        upd();
    })();
</script>