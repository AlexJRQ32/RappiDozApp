@model RappiDozApp.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - Rappi'Doz</title>
    <link rel="stylesheet" href="~/css/Accesos/register.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    @* Necesitamos SweetAlert2 aquí también *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>


    <div class="form">
        <h1>Registrarse</h1>

        <form id="registerForm" asp-controller="Usuarios" asp-action="Registrar" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <section>
                <div class="container-translucid">
                    <input asp-for="NombreCompleto" id="NombreCompleto" type="text" placeholder="Nombre completo" autofocus required>
                    <i class="fa-solid fa-user"></i>
                </div>
            </section>

            <section>
                <div class="container-translucid">
                    <input asp-for="Email" id="Email" type="email" placeholder="Correo electrónico" required>
                    <i class="fa-solid fa-envelope"></i>
                </div>
            </section>

            <section>
                <div class="container-translucid">
                    <input asp-for="PasswordHash" id="PasswordHash" type="password" placeholder="Contraseña" required autocomplete="new-password">
                    <i class="fa-solid fa-key"></i>
                </div>
            </section>

            <section>
                <div class="container-translucid">
                    <input type="password" name="confirmarPassword" id="confirmarPassword" placeholder="Confirmar contraseña" required autocomplete="new-password">
                    <i class="fa-solid fa-lock"></i>
                </div>
            </section>

            <section>
                <div class="container-translucid">
                    <input asp-for="Telefono" type="text" placeholder="Número telefónico">
                    <i class="fa-solid fa-phone"></i>
                </div>
            </section>


            @* Contenedor de errores oculto *@
            <div id="error-message" class="feedback-error hidden-feedback"></div>

            <section>
                <div class="container-button">
                    <button type="submit" id="button">Registrarse</button>
                </div>
            </section>

            <div class="register register-spaced">
                <a asp-action="Login" asp-controller="Accesos" id="register">¿Ya tienes una cuenta? Iniciar sesión</a>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('registerForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const form = this;
            const pass = document.getElementById('PasswordHash').value;
            const confirmPass = document.getElementById('confirmarPassword').value;
            const errorDiv = document.getElementById('error-message');
            const formData = new FormData(form);

            // Ocultar errores previos
            errorDiv.classList.add('hidden-feedback');

            // 1. Validación de contraseñas (Aviso de error inmediato si no coinciden)
            if (pass !== confirmPass) {
                Swal.fire({
                    icon: 'error',
                    title: 'Contraseñas diferentes',
                    text: 'Asegúrate de que ambas contraseñas sean idénticas.',
                    confirmButtonColor: '#d3ab80',
                    background: '#1e1c22',
                    color: '#ece4da'
                });
                return;
            }

            // 2. Envío directo por AJAX
            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.redirected) {
                    // AVISO DE ÉXITO: Registro completado
                    Swal.fire({
                        icon: 'success',
                        title: '¡Cuenta creada!',
                        text: 'Bienvenido a la familia Rappi\'Doz',
                        showConfirmButton: false,
                        timer: 2000,
                        background: '#1e1c22',
                        color: '#ece4da'
                    }).then(() => {
                        window.location.href = response.url;
                    });
                    return;
                }
                return response.text();
            })
            .then(data => {
                if (data) {
                    // AVISO DE ERROR: Fallo en el servidor (ej. correo duplicado)
                    errorDiv.textContent = "El correo ya está registrado o los datos son inválidos.";
                    errorDiv.classList.remove('hidden-feedback');

                    Swal.fire({
                        icon: 'warning',
                        title: 'No se pudo registrar',
                        text: 'Parece que este correo ya tiene una cuenta activa.',
                        confirmButtonColor: '#d3ab80',
                        background: '#1e1c22',
                        color: '#ece4da'
                    });
                }
            })
            .catch(error => {
                Swal.fire({
                    icon: 'error',
                    title: 'Error de conexión',
                    text: 'Inténtalo de nuevo en unos minutos.',
                    confirmButtonColor: '#d3ab80',
                    background: '#1e1c22',
                    color: '#ece4da'
                });
                console.error('Error:', error);
            });
        });
    </script>
</body>
</html>
