@model RappiDozApp.Models.Restaurante

@{
    Layout = null;
    int userId = ViewBag.UsuarioId ?? 0;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Restaurante - Rappi'Doz</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/Accesos/restaurante-info.css">
    @* Agregado SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>


    <div class="form">
        <div class="brand-mini">
            <span class="brand-rappi">Rappi</span><span class="brand-doz">'Doz</span>
        </div>

        <h1>Nuevo Restaurante</h1>

        <form id="restaurantForm" asp-controller="Accesos" asp-action="GuardarRestaurante" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="UsuarioId" value="@userId" />

            <section class="container-translucid">
                <input type="text" asp-for="NombreComercial" id="NombreComercial" placeholder="Nombre del negocio" required>
                <i class="fa-solid fa-shop"></i>
            </section>

            <section class="container-translucid">
                <input type="text" asp-for="Direccion" placeholder="Dirección exacta" required>
                <i class="fa-solid fa-location-dot"></i>
            </section>

            <div class="time-row">
                <div class="time-col">
                    <label class="label-time">Apertura</label>
                    <section class="container-translucid time-container">
                        <input type="time" asp-for="HoraApertura" required>
                        <i class="fa-regular fa-clock"></i>
                    </section>
                </div>
                <div class="time-col">
                    <label class="label-time">Cierre</label>
                    <section class="container-translucid time-container">
                        <input type="time" asp-for="HoraCierre" required>
                        <i class="fa-solid fa-moon"></i>
                    </section>
                </div>
            </div>

            <section class="container-translucid select-container">
                <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" required>
                    <option value="" disabled selected>Selecciona Categoría</option>
                </select>
                <i class="fa-solid fa-utensils"></i>
            </section>

            <div id="error-message" class="feedback-error hidden-feedback"></div>

            <div class="container-button">
                <button type="submit" id="button">
                    Registrar Negocio
                </button>
            </div>

            <div class="register register-spaced">
                <a asp-controller="Accesos" asp-action="Login"><i class="fa-solid fa-arrow-left"></i> Cancelar registro</a>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('restaurantForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const form = this;
            const errorDiv = document.getElementById('error-message');
            const formData = new FormData(form);

            // Ocultar errores previos
            errorDiv.classList.add('hidden-feedback');

            // Enviar directamente por AJAX
            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.redirected) {
                    // AVISO DE ÉXITO: Negocio registrado correctamente
                    Swal.fire({
                        icon: 'success',
                        title: '¡Negocio Registrado!',
                        text: 'Tu restaurante se ha creado correctamente.',
                        showConfirmButton: false,
                        timer: 2000,
                        background: '#1e1c22',
                        color: '#ece4da'
                    }).then(() => {
                        window.location.href = response.url;
                    });
                    return;
                }
                return response.text();
            })
            .then(data => {
                if (data) {
                    // AVISO DE ERROR: Problema en la validación del servidor
                    errorDiv.textContent = "Hubo un error al guardar los datos del restaurante.";
                    errorDiv.classList.remove('hidden-feedback');

                    Swal.fire({
                        icon: 'error',
                        title: 'No se pudo registrar',
                        text: 'Verifica que todos los campos sean válidos e inténtalo de nuevo.',
                        confirmButtonColor: '#d3ab80',
                        background: '#1e1c22',
                        color: '#ece4da'
                    });
                }
            })
            .catch(error => {
                // AVISO DE ERROR TÉCNICO
                Swal.fire({
                    icon: 'warning',
                    title: 'Error de servidor',
                    text: 'No pudimos conectar con el servidor. Inténtalo más tarde.',
                    confirmButtonColor: '#d3ab80',
                    background: '#1e1c22',
                    color: '#ece4da'
                });
                console.error('Error:', error);
            });
        });
    </script>
</body>
</html>
