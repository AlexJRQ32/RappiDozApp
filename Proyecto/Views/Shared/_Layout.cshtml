<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rappi'Doz</title>
    @{
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
        var action = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    @* 1. CSS LIBRARIES (Prioridad de Estilos) *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    @* 2. ESTILOS BASE *@
    <link rel="stylesheet" href="~/css/styles.css" />
    <link href="~/css/site.css" rel="stylesheet" />

    @* 3. ESTILOS COMPARTIDOS *@
    <link href="~/css/Shared/header.css" rel="stylesheet" />
    <link href="~/css/Shared/layout.css" rel="stylesheet" />
    <link href="~/css/Shared/seleccionar-cupon.css" rel="stylesheet" />
    <link href="~/css/Shared/page-transition.css" rel="stylesheet" />
    <link href="~/css/Valoraciones/calificanos.css" rel="stylesheet" />
    <link href="~/css/Ubicaciones/mapa.css" rel="stylesheet" />
    <link href="~/css/Usuarios/users-form.css" rel="stylesheet" />

    @* 4. ESTILOS POR PÁGINA *@
    @if (controller == "Home" && action == "Index")
    {
        <link href="~/css/Home/index.css" rel="stylesheet" />
    }
    else if (controller == "Home" && action == "Explorar")
    {
        <link href="~/css/Home/busqueda.css" rel="stylesheet" />
    }
    else if (controller == "Restaurantes")
    {
        <link href="~/css/Restaurantes/restaurante.css" rel="stylesheet" />
    }
    else if (controller == "Cupones")
    {
        <link href="~/css/Cupones/cupones.css" rel="stylesheet" />
    }
    else if (controller == "Pedidos" && action == "Factura")
    {
        <link href="~/css/Pedidos/factura.css" rel="stylesheet" />
    }
    else if (controller == "Pedidos" && action == "Seguimiento")
    {
        <link href="~/css/Pedidos/seguimiento.css" rel="stylesheet" />
    }
    else if (controller == "Pedidos" && action == "Movimientos")
    {
        <link href="~/css/Pedidos/movimientos.css" rel="stylesheet" />
    }
    else if (controller == "Carritos")
    {
        <link href="~/css/Carritos/carrito.css" rel="stylesheet" />
    }
    <link rel="icon" type="image/png" href="~/img/logo-final.png" />
</head>
<body>
    @await Html.PartialAsync("_PageTransition")

    @await Html.PartialAsync("_Header")

    @RenderBody()

    <div class="modal fade modal-general" id="modalGeneral" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content b-0">
                <div class="modal-body text-center pt-0 px-4 pb-4" id="modalBodyGeneral"></div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Footer")

    @* 1. SCRIPT LIBRARIES *@
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

    @* 2. TUS SCRIPTS ORIGINALES *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/page-transition.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
