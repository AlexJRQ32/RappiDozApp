@* Rappi'Doz Loader - Transición Única Continua *@
<div id="page-loader" class="page-loader">
  <div class="clouds-container">
    <div class="cloud c1"></div>
    <div class="cloud c2"></div>
    <div class="cloud c3"></div>
  </div>

  <div class="loader-wrapper">
    <div class="loader">
      <span class="top-fazers"><span></span><span></span><span></span><span></span></span>
      <div class="rider-body">
        <div class="torso-base">
          <div class="jetpack"></div>
          <div class="rider-face"></div>
        </div>
      </div>
    </div>
    <div class="longfazers"><span></span><span></span><span></span><span></span></div>
    <div class="loader-brand">
      <h2 class="brand-title">Rappi'Doz</h2>
      <p class="brand-slogan">¡VOLANDO POR TU ANTOJO!</p>
    </div>
  </div>
</div>

<script>
  (function() {
    const loader = document.getElementById('page-loader');

    // 1. COMPROBACIÓN DE ENTRADA: 
    // Si venimos de un clic interno, el loader debe nacer visible (abajo)
    if (sessionStorage.getItem('showLoader') === 'true') {
        loader.style.transition = 'none'; // Sin animación al aparecer para que no parpadee
        loader.classList.add('loader-active');
        sessionStorage.removeItem('showLoader'); // Limpiamos la marca
        
        // Forzamos el redibujado y devolvemos la animación para que al irse sí sea suave
        setTimeout(() => {
            loader.style.transition = 'transform 0.6s cubic-bezier(0.8, 0, 0.2, 1)';
            loader.classList.remove('loader-active');
        }, 500);
    }

    // 2. DETECTOR DE CLIC (SALIDA):
    document.addEventListener("click", function(e) {
      const link = e.target.closest('a');
      if (!link) return;

      const href = link.getAttribute('href');
      const target = link.getAttribute('target');

      if (!href || href.startsWith('#') || href.includes("javascript") || target === "_blank") {
        return; 
      }

      // Marcamos que la siguiente página DEBE mostrar el loader
      sessionStorage.setItem('showLoader', 'true');
      
      // Bajamos el loader inmediatamente
      loader.classList.add('loader-active');
    });

    // 3. SEGURIDAD: Si por alguna razón la carga falla, ocultar el loader tras 5 seg
    window.addEventListener("load", function() {
        if (!sessionStorage.getItem('showLoader')) {
            loader.classList.remove('loader-active');
        }
    });
  })();
</script>