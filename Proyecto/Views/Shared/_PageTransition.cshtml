@* Rappi'Doz Loader - Restaurado con Fix de Parpadeo *@

<div id="page-loader" class="page-loader" style="display: none;">
    <div class="loader-content">
        <div class="burger-arena">
            <div class="burger" id="burger-main">
                <div class="ingredient bun-top"></div>
                <div class="ingredient lettuce"></div>
                <div class="ingredient cheese"></div>
                <div class="ingredient meat"></div>
                <div class="ingredient bun-bottom"></div>
                <div class="bite-fancy b1"></div>
                <div class="bite-fancy b2"></div>
                <div class="bite-fancy b3"></div>
            </div>
            <div class="crumb" id="final-crumb"></div>
        </div>
        <h2 class="loader-logo">Rappi'Doz</h2>
        <div class="loading-text">PREPARANDO TU ANTOJO<span>.</span><span>.</span><span>.</span></div>
    </div>
</div>

<style>
    :root {
        --fondo-beige: #fff4e2;
        --cafe-marca: #472825;
        --dorado: #d3ab80;
    }

    .page-loader {
        position: fixed;
        top: -15px; /* Restaurado */
        left: 0;
        width: 100vw;
        height: 115vh; /* Restaurado */
        background-color: var(--fondo-beige);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 100000;
        transition: transform 0.85s cubic-bezier(0.8, 0, 0.1, 1);
        backface-visibility: hidden;
        transform: translateY(0) translateZ(0);
        will-change: transform;
        outline: 1px solid transparent;
    }

    .is-active {
        display: flex !important;
    }

    .page-loader.is-loaded {
        transform: translateY(-115%) translateZ(0);
    }

    /* --- Tus estilos originales de la burger --- */
    .burger-arena {
        position: relative;
        width: 160px;
        height: 100px;
        margin: 0 auto 25px;
    }

    .ingredient {
        width: 100%;
        border-radius: 12px;
        position: absolute;
        opacity: 0;
        transform: translateY(-80px);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .bun-top {
        height: 35px;
        background: #e28e43;
        top: 0;
        border-radius: 60px 60px 12px 12px;
        z-index: 5;
    }

    .lettuce {
        height: 10px;
        background: #87c55d;
        top: 38px;
        z-index: 4;
    }

    .cheese {
        height: 8px;
        background: #f1c40f;
        top: 46px;
        z-index: 3;
        width: 95%;
        left: 2.5%;
    }

    .meat {
        height: 22px;
        background: #704028;
        top: 52px;
        z-index: 2;
    }

    .bun-bottom {
        height: 20px;
        background: #e28e43;
        top: 72px;
        border-radius: 6px 6px 30px 30px;
        z-index: 1;
    }

    .animate-drop {
        opacity: 1;
        transform: translateY(0);
    }

    .bite-fancy {
        position: absolute;
        background: var(--fondo-beige);
        border-radius: 50%;
        opacity: 0;
        z-index: 20;
        transform: scale(0);
        transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .b1 {
        width: 125px;
        height: 125px;
        top: -30px;
        right: -50px;
    }

    .b2 {
        width: 115px;
        height: 115px;
        bottom: -40px;
        left: -30px;
    }

    .b3 {
        width: 140px;
        height: 140px;
        top: -20px;
        left: 20px;
    }

    .animate-bite-fancy {
        opacity: 1;
        transform: scale(1);
    }

    .crumb {
        position: absolute;
        width: 7px;
        height: 5px;
        background: #e28e43;
        border-radius: 45%;
        bottom: 15px;
        right: 40px;
        opacity: 0;
        z-index: 25;
    }

    .loader-logo {
        color: var(--cafe-marca);
        font-weight: 900;
        font-size: 2.5rem;
        text-align: center;
        margin: 0;
    }

    .loading-text {
        color: var(--dorado);
        font-size: 0.85rem;
        font-weight: bold;
        letter-spacing: 3px;
        text-align: center;
    }
</style>

<script>
    (function() {
        const currentBaseUrl = window.location.origin + window.location.pathname;
        const lastBaseUrl = sessionStorage.getItem('lastBaseUrl');

        // Si es la misma URL (refresco), no mostramos nada
        if (lastBaseUrl === currentBaseUrl) return;

        // Mostramos el loader de inmediato para evitar el parpadeo blanco
        document.getElementById('page-loader').classList.add('is-active');

        window.addEventListener("load", function() {
            const loader = document.getElementById('page-loader');
            const ingredients = document.querySelectorAll('.ingredient');

            // 1. Activamos todas las animaciones al mismo tiempo (vía CSS)
            ingredients.forEach(ing => ing.classList.add('animate-drop'));

            // 2. Registramos la visita
            sessionStorage.setItem('lastBaseUrl', currentBaseUrl);

            // 3. Ocultamos el loader inmediatamente (o con un mini delay de 100ms para suavidad)
            setTimeout(() => {
                loader.classList.add('is-loaded');
            }, 100);
        });
    })();

    // Lógica para mostrarlo al hacer click en links (Navegación saliente)
    document.addEventListener("DOMContentLoaded", function() {
        const loader = document.getElementById('page-loader');

        document.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', (e) => {
                const href = link.getAttribute('href');
                const onclick = link.getAttribute('onclick') || "";

                if (!href || href.startsWith('#') || href.includes("javascript:void(0)") ||
                    link.hasAttribute('data-bs-toggle') || href.toLowerCase().includes("eliminar")) {
                    return;
                }

                loader.classList.remove('is-loaded');
                loader.classList.add('is-active');
            });
        });

        // Lógica para formularios
        document.querySelectorAll('form').forEach(form => {
            form.addEventListener('submit', (e) => {
                const action = (form.getAttribute('action') || "").toLowerCase();
                const id = form.getAttribute('id') || "";

                if (action.includes("agregar") || action.includes("actualizarcantidad") ||
                    id === "formPerfilUsuario" || id === "formCalificar") {
                    return;
                }

                loader.classList.remove('is-loaded');
                loader.classList.add('is-active');
            });
        });
    });
</script>