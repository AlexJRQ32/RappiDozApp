@model dynamic
@{
    Layout = null;
    bool esRestaurante = ViewBag.EsRestaurante ?? false;
    string lat = "9.9333";
    string lng = "-84.0833";

    if (Model != null)
    {
        try
        {
            lat = ((decimal)Model.Latitud).ToString(System.Globalization.CultureInfo.InvariantCulture);
            lng = ((decimal)Model.Longitud).ToString(System.Globalization.CultureInfo.InvariantCulture);
        }
        catch { }
    }
}

<div class="modal-content-custom position-relative">
    <div class="p-4">
        <div class="text-center mb-4">
            <h4 class="mapa-title">@(esRestaurante ? "Ubica tu Restaurante" : "Nueva Dirección de Entrega")</h4>
            <p class="text-muted small">Mueve el pin sobre tu ubicación</p>
        </div>

        <div id="mapa-final" data-lat="@lat" data-lng="@lng" style="height: 350px; width: 100%; border-radius: 20px;"></div>

        @if (!esRestaurante)
        {
            <div class="mt-3">
                <label class="label-custom">¿CÓMO LLAMARÁS A ESTA DIRECCIÓN?</label>
                <input type="text" id="nombre-ubicacion" class="form-control input-rappi" placeholder="Ej: Mi Casa, Oficina...">
            </div>
        }

        <input type="hidden" id="lat-hidden" value="@lat">
        <input type="hidden" id="lng-hidden" value="@lng">

        <button type="button" id="btnConfirmarFinal" class="btn btn-rappi-confirm w-100 mt-3">
            <i class="fas fa-check-circle me-1"></i> GUARDAR DIRECCIÓN
        </button>
    </div>
</div>

<script src="~/js/Ubicaciones/mapa.js" asp-append-version="true"></script>