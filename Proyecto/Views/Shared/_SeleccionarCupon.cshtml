@model List<RappiDozApp.Models.CuponApartado>

<div class="wallet-container" style="margin-top: 10px;">
    <p style="color: #472825; font-weight: 800; font-size: 0.85rem; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px;">
        <i class="fas fa-wallet" style="color: #d3ab80;"></i> Tus cupones guardados
    </p>

    @if (Model == null || !Model.Any())
    {
        <div style="border: 2px dashed #fde4bc; padding: 15px; border-radius: 15px; text-align: center; background: #fffcf8;">
            <small style="color: #96786f; font-style: italic;">No tienes cupones en tu billetera.</small>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 10px;">
            @foreach (var cupon in Model)
            {
                @* CARD DE CUPÓN CLARO *@
                <div onclick="activarCuponParaCompra('@cupon.Codigo', @cupon.Descuento, @(cupon.EsPorcentaje.ToString().ToLower()))"
                     style="background: white; border: 1.5px solid #fde4bc; padding: 12px; border-radius: 15px; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4px 10px rgba(0,0,0,0.02);">

                    <div style="display: flex; align-items: center; gap: 12px;">
                        <div style="background: #472825; color: #d3ab80; width: 35px; height: 35px; border-radius: 10px; display: grid; place-items: center;">
                            <i class="fas fa-tag" style="font-size: 0.8rem;"></i>
                        </div>
                        <div>
                            <span style="display: block; color: #472825; font-weight: 800; font-size: 0.9rem;">@cupon.Codigo</span>
                            <small style="color: #27ae60; font-weight: 700;">
                                @(cupon.EsPorcentaje? cupon.Descuento + "% DTO" : "₡" + cupon.Descuento.ToString("N0") + " menos")
                            </small>
                        </div>
                    </div>
                    <i class="fas fa-plus-circle" style="color: #d3ab80;"></i>
                </div>
            }
        </div>
    }
</div>

