@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@inject IHttpContextAccessor HttpContextAccessor
@inject RappiDozApp.Data.ApplicationDbContext _context

@{
    var nombreUsuario = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
    var fotoUsuario = HttpContextAccessor.HttpContext.Session.GetString("FotoUsuario");
    var rolUsuario = HttpContextAccessor.HttpContext.Session.GetString("RolUsuario");
    var carritoCount = HttpContextAccessor.HttpContext.Session.GetString("CarritoCount");
    int? idUsuarioSesion = HttpContextAccessor.HttpContext.Session.GetInt32("UsuarioId");

    bool tieneUbicacion = false;
    if (idUsuarioSesion.HasValue)
    {
        tieneUbicacion = _context.UbicacionUsuario.Any(u => u.IdUsuario == idUsuarioSesion.Value);
    }

    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    var action = ViewContext.RouteData.Values["Action"]?.ToString();

    string ClaseActiva(string c, string a = "")
    {
        bool esActivo = string.IsNullOrEmpty(a) ? controller == c : (controller == c && action == a);
        return esActivo ? "link-activo" : "";
    }
}

<style>
    /* ==========================================
       ESTILOS ORIGINALES (ESCRITORIO)
    ========================================== */
    .navbar {
        background-color: #472825;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 5px 25px;
        position: fixed;
        top: 0; left: 0; width: 100%;
        z-index: 10000;
        height: 80px;
        box-sizing: border-box;
    }

    .navbar-brand img { height: 100px; width: auto; }
    .sesion { display: flex; align-items: center; gap: 15px; }

    .sesion a, .dropdown-btn {
        color: #fff4e2;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 15px;
        border-radius: 20px;
        transition: 0.3s;
        background: transparent;
        border: none;
        cursor: pointer;
    }

    .sesion a:hover, .dropdown-btn:hover { background-color: rgba(211, 171, 128, 0.2); }
    .link-activo { background-color: rgba(0, 0, 0, 0.3) !important; color: #d3ab80 !important; }

    .menu-toggle { display: none; background: none; border: none; color: #fff4e2; font-size: 2rem; cursor: pointer; }

    .cart-container { position: relative; }
    .cart-badge {
        position: absolute; top: -5px; right: -5px;
        background-color: #ff4d4d; color: white;
        font-size: 0.7rem; min-width: 18px; height: 18px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        border: 2px solid #472825; font-weight: bold;
    }

    .dropdown { position: relative; }
    .dropdown-content {
        display: none; position: absolute; right: 0;
        background-color: #472825; min-width: 200px;
        box-shadow: 0px 8px 16px rgba(0,0,0,0.4);
        border: 1px solid #d3ab80; border-radius: 12px;
        overflow: hidden; z-index: 1001;
    }
    .dropdown:hover .dropdown-content { display: block; }
    .dropdown-content a { border-radius: 0; width: 100%; justify-content: flex-start; padding: 12px 18px; }

    /* USER-PILL MEJORADA */
    .user-pill {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(211, 171, 128, 0.1);
        padding: 6px 16px;
        border-radius: 50px;
        border: 1px solid rgba(211, 171, 128, 0.3);
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
    }
    .user-pill:hover { background: rgba(211, 171, 128, 0.2); border-color: #d3ab80; }
    
    .user-pill img {
        width: 32px; height: 32px;
        border-radius: 50%; object-fit: cover;
        border: 2px solid #d3ab80;
    }

    .user-info-text { display: flex; flex-direction: column; line-height: 1.1; text-align: left; }
    .user-name { color: #fff4e2; font-weight: 700; font-size: 0.85rem; }
    .user-role { color: #d3ab80; font-size: 0.65rem; text-transform: uppercase; font-weight: 800; }

    /* ==========================================
       RESPONSIVE
    ========================================== */
    @@media (max-width: 992px) {
        .menu-toggle { display: block; }
        
        .sesion {
            display: none; 
            flex-direction: column;
            align-items: center;
            position: absolute;
            top: 80px; left: 0; width: 100%;
            background-color: #472825;
            padding: 20px 0;
            gap: 10px;
        }

        .sesion.active { display: flex; }

        .sesion > a, .dropdown, .cart-container, .user-pill {
            width: 85% !important; 
        }

        .dropdown-content {
            position: static; 
            width: 100% !important; 
            background: rgba(0,0,0,0.2); 
            border: none;
            box-shadow: none;
        }
    }
</style>

<nav class="navbar">
    <a asp-controller="Home" asp-action="Index" class="navbar-brand">
        <img src="~/img/logo-final.png" alt="Logo">
    </a>

    <button type="button" class="menu-toggle" id="btn-menu">
        <i class="fa-solid fa-bars"></i>
    </button>

    <div class="sesion" id="navbar-menu">
        @if (!string.IsNullOrEmpty(nombreUsuario))
        {
            <a asp-controller="Home" asp-action="Index" class="@ClaseActiva("Home", "Index")">
                <i class="fa-solid fa-house"></i> Inicio
            </a>
            
            <a asp-controller="Home" asp-action="Explorar" class="@ClaseActiva("Home", "Explorar")">
                <i class="fa-solid fa-magnifying-glass"></i> Búsqueda
            </a>

            <a href="javascript:void(0);" onclick="window.abrirMapa()">
                <i class="fa-solid fa-location-dot"></i> Ubicación
                @if (!tieneUbicacion) { <span style="color: #ff4d4d; font-weight: bold;">!</span> }
            </a>

            <div class="cart-container">
                <a asp-controller="Carritos" asp-action="Index" class="@ClaseActiva("Carritos")">
                    <i class="fa-solid fa-cart-shopping"></i> Carrito
                </a>
                @if (!string.IsNullOrEmpty(carritoCount) && carritoCount != "0") {
                    <span class="cart-badge">@carritoCount</span>
                }
            </div>

            <div class="dropdown">
                <button class="dropdown-btn">
                    <i class="fa-solid fa-ellipsis-vertical"></i> Más
                </button>
                <div class="dropdown-content">
                    <a asp-controller="Usuarios" asp-action="Movimientos"><i class="fa-solid fa-clock-rotate-left"></i> Mis Pedidos</a>
                    <a asp-controller="Cupones" asp-action="Index"><i class="fa-solid fa-ticket"></i> Cupones</a>
                    <a href="javascript:void(0)" onclick="abrirCalificar()">
                        <i class="fa-solid fa-star"></i> Califícanos
                    </a>

                    @if (rolUsuario == "Administrador" || rolUsuario == "Restaurante")
                    {
                        <div style="height: 1px; background: rgba(211, 171, 128, 0.3); margin: 8px 15px;"></div>
                        <a asp-controller="Dashboard" asp-action="Index"><i class="fa-solid fa-gauge-high"></i> Panel Admin</a>
                    }
                </div>
            </div>

            <div class="dropdown">
                <div class="user-pill">
                    @if (!string.IsNullOrEmpty(fotoUsuario)) {
                        <img src="data:image/png;base64,@fotoUsuario" alt="User">
                    } else {
                        <i class="fa-solid fa-circle-user" style="color: #d3ab80; font-size: 1.8rem;"></i>
                    }
                    <div class="user-info-text">
                        <span class="user-name">@nombreUsuario</span>
                        <span class="user-role">@rolUsuario</span>
                    </div>
                </div>
                <div class="dropdown-content">
                    <a href="javascript:void(0);" onclick="abrirPerfil()">
                        <i class="fa-solid fa-user-gear"></i> Mi Cuenta
                    </a>
                    <div style="height: 1px; background: rgba(211, 171, 128, 0.3); margin: 8px 15px;"></div>
                    <a href="javascript:void(0);" onclick="confirmarSalida()" style="color: #ff4d4d !important;">
                        <i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión
                    </a>
                </div>
            </div>
        }
        else
        {
            <a asp-controller="Accesos" asp-action="Login" style="border: 2px solid #d3ab80; border-radius: 50px;">
                <i class="fa-solid fa-circle-user"></i> Iniciar sesión
            </a>
        }
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const btnMenu = document.getElementById('btn-menu');
        const navbarMenu = document.getElementById('navbar-menu');
        if(btnMenu && navbarMenu) {
            btnMenu.onclick = function() {
                navbarMenu.classList.toggle('active');
            };
        }
    });

    function confirmarSalida() {
        Swal.fire({
            title: '¿Cerrar sesión?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#472825',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sí, salir',
            background: '#fff4e2',
            color: '#472825',
            didOpen: () => {
            // Esto asegura que el contenedor de la alerta sea el rey del z-index
                const container = document.querySelector('.swal2-container');
                if (container) {
                    container.style.zIndex = '15000';
                }
            },
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '@Url.Action("Salir", "Acceso")';
            }
        });
    }

    
</script>