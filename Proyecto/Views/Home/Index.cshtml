@using Microsoft.AspNetCore.Http
@using System.Globalization
@inject IHttpContextAccessor HttpContextAccessor
@inject RappiDozApp.Data.ApplicationDbContext _context
@model IEnumerable<RappiDozApp.Models.Restaurante>

@{
    ViewData["Title"] = "Inicio | RappiDoz";
    var userId = HttpContextAccessor.HttpContext.Session.GetInt32("UsuarioId");

    // VALORES POR DEFECTO (San José)
    bool tieneUbicacion = false;
    double latActual = 9.9331; 
    double lngActual = -84.1112;

    if (userId.HasValue)
    {
        try 
        {
            // Buscamos la última ubicación guardada
            var ultimaUbi = _context.UbicacionUsuario
                .Where(u => u.IdUsuario == userId.Value)
                .OrderByDescending(u => u.IdUbicacion) // Asegúrate que el nombre sea Id o IdUbicacion según tu clase
                .FirstOrDefault();

            if (ultimaUbi != null)
            {
                tieneUbicacion = true;
                // USAMOS CONVERT PARA EVITAR EL ERROR DE CAST (Double vs Single)
                latActual = Convert.ToDouble(ultimaUbi.Latitud);
                lngActual = Convert.ToDouble(ultimaUbi.Longitud);
            }
        }
        catch (Exception) 
        {
            // Si hay error de casteo o base de datos, mantenemos los valores por defecto
            tieneUbicacion = false;
        }
    }
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    /* --- HERO --- */
    .hero { margin-top: 55px; }

    /* ESTILOS DE CARTAS */
    .restaurant-card.cerrado-filtro .card-img-wrapper img { filter: brightness(0.5) saturate(1); opacity: 0.8; }
    .restaurant-card.cerrado-filtro .card-img-wrapper::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.4); z-index: 5; }
    .restaurant-card.cerrado-filtro { cursor: not-allowed; pointer-events: none; background-color: #fafafa; }
    
    .badge-cerrado {
        background: #472825; color: white; padding: 6px 14px; border-radius: 8px;
        font-weight: 800; font-size: 0.75rem; text-transform: uppercase;
        box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    }

    /* GRID Y SCROLL */
    .scroll-horizontal-wrapper { width: 100%; overflow-x: auto; display: flex; padding-bottom: 25px; scrollbar-width: none; }
    .scroll-horizontal-wrapper::-webkit-scrollbar { display: none; }
    .grid-restaurantes-dinamico { display: flex; gap: 20px; padding: 0 40px; }
    .link-restaurante-horizontal { text-decoration: none !important; color: inherit; flex: 0 0 200px; }
    
    .restaurant-card { 
        background: white; border-radius: 20px; overflow: hidden; border: 1px solid #f3e5d0; 
        height: 300px; display: flex; flex-direction: column; transition: 0.3s; 
    }
    .restaurant-card:hover:not(.cerrado-filtro) { transform: translateY(-8px); box-shadow: 0 10px 20px rgba(71, 40, 37, 0.08); }

    .card-img-wrapper { height: 160px; position: relative; overflow: hidden; background: #eee; }
    .restaurant-logo { width: 100%; height: 100%; object-fit: cover; }
    .info { padding: 12px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
    .info h3 { font-size: 0.95rem; color: #472825; font-weight: 800; margin: 0; }
    .meta { font-size: 0.8rem; font-weight: 700; color: #d3ab80; }

/* PASOS - DISEÑO MEJORADO */
.como-funciona { 
    background: #fdf2e2; 
    padding: 80px 0; 
    margin-top: 60px;
    border-radius: 50px 50px 0 0; /* Suaviza la transición con la sección anterior */
}

.pasos { 
    display: flex; 
    justify-content: center; 
    gap: 40px; 
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
}

.paso { 
    text-align: center; 
    flex: 1;
    min-width: 250px;
    max-width: 320px;
    padding: 30px 20px;
    background: rgba(255, 255, 255, 0.4); /* Un toque de transparencia blanca */
    border-radius: 30px;
    transition: all 0.4s ease;
}

.paso:hover {
    background: #ffffff;
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(71, 40, 37, 0.05);
}

.paso i { 
    font-size: 3.5rem; 
    color: #d3ab80; 
    margin-bottom: 20px;
    display: inline-block;
    transition: transform 0.3s ease;
}

.paso:hover i {
    transform: scale(1.1) rotate(5deg);
    color: #472825; /* Cambia al color principal al pasar el mouse */
}

.paso h3 {
    color: #472825;
    font-weight: 800;
    font-size: 1.25rem;
    margin-bottom: 10px;
}

.paso p {
    color: #7a6e6c;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
}
/* SECCIÓN MAPA MEJORADA */
    .map-card { max-width:900px; margin:0 auto; background:white; padding:25px; border-radius:30px; position:relative; box-shadow:0 10px 30px rgba(0,0,0,0.05); }
    #map { height:350px; width:100%; border-radius:20px; z-index:1; border: 2px solid #f3e5d0; }
    
    .input-nombre-ubi {
        width: 100%; padding: 12px; border-radius: 12px; border: 2px solid #f3e5d0;
        margin-bottom: 15px; outline: none; transition: 0.3s;
    }
    .input-nombre-ubi:focus { border-color: #d3ab80; }

    /* RESPONSIVE */
@@media (max-width: 768px) {
        .link-restaurante-horizontal { flex: 0 0 160px; }
    .restaurant-card { height: 210px; display: flex; flex-direction: column; }
    .card-img-wrapper { height: 150px !important; border-bottom: 1px solid #f3e5d0; }
    .restaurant-logo { height: 100%; width: 100%; object-fit: cover; }
    .info { height: 50px; padding: 4px 8px !important; display: flex; flex-direction: column; justify-content: center; background: white; }
    .info h3 { font-size: 0.8rem !important; margin: 0 !important; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .horario-mini, .info p:not(.meta) { display: none !important; }
    .meta { font-size: 0.65rem !important; margin: 7px 0 0 0 !important; line-height: 1; }
    .overlay-cerrado { background-color: rgba(0,0,0,0.2); }
    .badge-cerrado { font-size: 0.55rem; padding: 2px 6px; }
}

/* Utility classes to replace inline styles used in the view */
.hero-content h1 { color: white; }
.contenido-principal { background-color: #fff4e2; min-height: 100vh; }
.categorias { padding: 40px 0; }
.grid-categorias { display:flex; justify-content:center; flex-wrap:wrap; gap:15px; }
.categoria-card p { font-size: 0.8rem; }
.restaurantes { padding: 20px 0; }
.restaurantes .container-header { max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding:0 20px; }
.restaurantes .container-header h2 { color:#472825; font-weight:800; margin:0; }
.restaurantes .container-header a { color:#d3ab80; font-weight:700; text-decoration:none; }
.seccion-mapa { padding: 40px 20px; }
.map-card { max-width:900px; margin:0 auto; background:white; padding:25px; border-radius:30px; position:relative; box-shadow:0 10px 30px rgba(0,0,0,0.05); }
.map-card #map { height:350px; width:100%; border-radius:20px; z-index:1; }
.locked-overlay { position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.7); border-radius:30px; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:1000; backdrop-filter: blur(4px); }
.locked-overlay i { font-size:3rem; color:#472825; margin-bottom:15px; }
.locked-overlay h3 { color:#472825; font-weight:800; }
.locked-overlay a { background:#472825; color:white; padding:12px 30px; border-radius:15px; text-decoration:none; font-weight:bold; margin-top:10px; }
.btn-confirmar-mapa { margin-top:20px; }
</style>

@* HERO SECCIÓN *@
<section class="hero">
    <div class="hero-content">
        <h1 style="color:white;">Entrega de comida hasta tu puerta</h1>
        <form asp-controller="Home" asp-action="Explorar" method="get" class="search-container">
            <div class="input-wrapper">
                <i class="fas fa-map-marker-alt"></i>
                <input type="text" name="buscar" placeholder="Ingresar dirección de entrega" required>
            </div>
            <button type="submit" class="btn-buscar">Buscar comida</button>
        </form>
    </div>
</section>

<main class="contenido-principal" style="background-color: #fff4e2; min-height: 100vh;">
    <div class="zona-restringida">

        @* CATEGORÍAS *@
        <section class="categorias" style="padding: 40px 0;">
            <h2 style="text-align: center; color: #472825; font-weight: 800; margin-bottom: 30px;">Explorar por categoría</h2>
            <div class="grid-categorias" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 15px;">
                @foreach (var cat in new[] { (I: "hamburger", N: "Burgers"), (I: "pizza-slice", N: "Pizza"), (I: "drumstick-bite", N: "Pollo"), (I: "ice-cream", N: "Postres"), (I: "utensils", N: "Más") })
                {
                    <a asp-controller="Home" asp-action="Explorar" asp-route-buscar="@cat.N" class="categoria-card">
                        <i class="fas fa-@cat.I"></i>
                        <p>@cat.N</p>
                    </a>
                }
            </div>
        </section>

        @* RESTAURANTES *@
        <section class="restaurantes" style="padding: 20px 0;">
            <div style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding: 0 20px;">
                <h2 style="color: #472825; font-weight: 800; margin: 0;">Restaurantes populares</h2>
                <a asp-action="Explorar" asp-controller="Home" style="color: #d3ab80; font-weight: 700; text-decoration: none;">Ver todos</a>
            </div>

            <div class="scroll-horizontal-wrapper">
                <div class="grid-restaurantes-dinamico">
                    @if (Model != null)
                    {
                        @foreach (var restaurante in Model)
                        {
                            <a asp-controller="Restaurante" asp-action="Menu" asp-route-id="@restaurante.Id" class="link-restaurante-horizontal">
                                <div class="restaurant-card @(restaurante.EstaAbierto ? "" : "cerrado-filtro")">
                                    <div class="card-img-wrapper">
                                        <img src="data:@(restaurante.ContentType ?? "image/png");base64,@Convert.ToBase64String(restaurante.LogoBinario ?? new byte[0])" class="restaurant-logo">
                                        @if (!restaurante.EstaAbierto)
                                        {
                                            <div style="position: absolute; top:0; left:0; width:100%; height:100%; display:flex; align-items:center; justify-content:center; z-index:10;">
                                                <span class="badge-cerrado">CERRADO</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="info">
                                        <h3>@restaurante.NombreComercial</h3>
                                        <p style="font-size:0.75rem; color:#888;"><i class="fa-regular fa-clock"></i> @restaurante.HoraApertura.ToString(@"hh\:mm") - @restaurante.HoraCierre.ToString(@"hh\:mm")</p>
                                        <p class="meta">⭐ 4.8 • 20 min</p>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </section>

        @* SECCIÓN MAPA ACTUALIZADA *@
        <section id="seccion-mapa" style="padding: 40px 20px;">
            <div class="map-card">
                <h2 style="color: #472825; font-weight: 800; margin-bottom: 20px; text-align: center;">¿A dónde enviamos hoy?</h2>
                
                <div id="map"></div>

                @if (userId == null)
                {
                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); border-radius: 30px; display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
                        <i class="fas fa-lock" style="font-size: 3rem; color: #472825; margin-bottom: 15px;"></i>
                        <h3 style="color: #472825; font-weight: 800;">Inicia sesión para guardar ubicaciones</h3>
                        <a asp-controller="Acceso" asp-action="Login" style="background:#472825; color:white; padding:12px 30px; border-radius:15px; text-decoration:none; font-weight:bold; margin-top:10px;">INICIAR SESIÓN</a>
                    </div>
                }
                else
                {
                    <form id="formUbicacion" asp-controller="Usuario" asp-action="GuardarUbicacion" method="post" style="margin-top: 20px;">
                        @Html.AntiForgeryToken()
                        
                        <div style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom:5px; font-weight:bold; color:#472825;">Etiqueta tu dirección:</label>
                            <input type="text" name="nombreUbicacion" class="input-nombre-ubi" placeholder="Ej: Casa, Trabajo, Gimnasio..." required>
                        </div>

                        <input type="hidden" id="Latitud" name="Latitud" value="@latActual.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        <input type="hidden" id="Longitud" name="Longitud" value="@lngActual.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                        
                        <button type="submit" id="btn-confirmar-mapa" style="background:#472825; color:white; border:none; width:100%; padding:15px; border-radius:15px; font-weight:800; cursor:pointer; transition: 0.3s;">
                            <i class="fas fa-map-pin me-2"></i> GUARDAR ESTA DIRECCIÓN
                        </button>
                    </form>
                }
            </div>
        </section>

        @* PASOS *@
        <section class="como-funciona">
            <div class="pasos">
                <div class="paso">
                    <i class="fas fa-map-marker-alt"></i>
                    <h3>Ingresa dirección</h3>
                    <p>Dinos dónde estás para mostrarte los restaurantes con cobertura en tu zona.</p>
                </div>
        
                <div class="paso">
                    <i class="fas fa-utensils"></i>
                    <h3>Elige tu comida</h3>
                    <p>Navega por los menús de tus comercios favoritos y arma tu pedido ideal.</p>
                </div>
        
                <div class="paso">
                    <i class="fas fa-motorcycle"></i>
                    <h3>Recibe rápido</h3>
                    <p>¡Y listo! Nuestros repartidores vuelan para entregarte tu antojo calientito.</p>
                </div>
            </div>
        </section>
    </div>
</main>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. INICIALIZACIÓN DEL MAPA
            const latIni = parseFloat("@latActual.ToString(System.Globalization.CultureInfo.InvariantCulture)");
            const lngIni = parseFloat("@lngActual.ToString(System.Globalization.CultureInfo.InvariantCulture)");

            const map = L.map('map').setView([latIni, lngIni], 15);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);

            const marker = L.marker([latIni, lngIni], { draggable: true }).addTo(map);

            // 2. EVENTOS DEL MARCADOR
            function actualizarInputs(lat, lng) {
                document.getElementById("Latitud").value = lat;
                document.getElementById("Longitud").value = lng;
            }

            marker.on('dragend', function (e) {
                const pos = e.target.getLatLng();
                actualizarInputs(pos.lat, pos.lng);
            });

            map.on('click', function (e) {
                marker.setLatLng(e.latlng);
                actualizarInputs(e.latlng.lat, e.latlng.lng);
            });

            // 3. ENVÍO POR AJAX (GUARDAR UBICACIÓN)
            const formUbi = document.getElementById('formUbicacion');
            if (formUbi) {
                formUbi.addEventListener('submit', function (e) {
                    e.preventDefault();
                    
                    const btn = document.getElementById('btn-confirmar-mapa');
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

                    const formData = new FormData(this);

                    fetch(this.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '¡Dirección Guardada!',
                                text: data.message,
                                confirmButtonColor: '#472825'
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                            btn.disabled = false;
                            btn.innerHTML = '<i class="fas fa-map-pin me-2"></i> GUARDAR ESTA DIRECCIÓN';
                        }
                    })
                    .catch(err => {
                        console.error("Error:", err);
                        btn.disabled = false;
                    });
                });
            }
        });
    </script>
}