@using System.Linq
@model IEnumerable<RappiDozApp.Models.Pedido>

@{
    ViewData["Title"] = "Mis Comprobantes | Rappi'Doz";
}

<div class="movimientos-container" style="background-color: #fde4bc; min-height: 100vh; padding: 120px 20px 60px; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <div class="movimientos-card" style="max-width: 1000px; margin: auto; background: #fff4e2; padding: 40px; border-radius: 30px; border: 2px solid #d3ab80; box-shadow: 0 10px 30px rgba(71, 40, 37, 0.1);">

        @* Encabezado de la Sección *@
        <div class="header-seccion" style="display: flex; align-items: center; gap: 20px; margin-bottom: 40px; border-bottom: 4px solid #fde4bc; padding-bottom: 20px;">
            <i class="fa-solid fa-receipt" style="font-size: 3rem; color: #472825;"></i>
            <h1 style="color: #472825; font-weight: 900; margin: 0; font-size: 2.5rem;">Mis Comprobantes</h1>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div style="text-align: center; padding: 100px 0;">
                <i class="fa-solid fa-box-open" style="font-size: 4rem; color: #d3ab80; margin-bottom: 20px;"></i>
                <p style="font-size: 1.5rem; color: #472825; font-weight: 700;">Aún no tienes pedidos registrados.</p>
                <a asp-controller="Home" asp-action="Index" style="display: inline-block; background: #472825; color: white; padding: 15px 35px; border-radius: 15px; text-decoration: none; margin-top: 20px; font-weight: bold; transition: 0.3s;">Explorar Restaurantes</a>
            </div>
        }
        else
        {
            @foreach (var pedido in Model)
            {
                <details style="background: white; margin-bottom: 20px; border-radius: 20px; border: 1px solid #fde4bc; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); transition: 0.3s;">
                    <summary style="padding: 25px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; list-style: none; outline: none;">
                        <div>
                            <p style="font-size: 1.4rem; font-weight: 900; color: #472825; margin: 0;">Orden #@pedido.Id</p>
                            <p style="color: #96786f; margin: 5px 0 0 0; font-size: 0.9rem;">
                                <i class="fa-regular fa-calendar-days"></i> @pedido.FechaHora.ToString("D")
                                <i class="fa-regular fa-clock" style="margin-left: 10px;"></i> @pedido.FechaHora.ToString("t")
                            </p>
                        </div>
                        <div style="text-align: right;">
                            @{
                                // Lógica de colores para el estado
                                string bgColor = pedido.Estado == "Entregado" ? "#e8f5e9" : (pedido.Estado == "Cancelado" ? "#ffebee" : "#fde4bc");
                                string textColor = pedido.Estado == "Entregado" ? "#2e7d32" : (pedido.Estado == "Cancelado" ? "#c62828" : "#472825");
                            }
                            <span style="background: @bgColor; color: @textColor; padding: 6px 18px; border-radius: 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">
                                @pedido.Estado
                            </span>
                            <div style="font-size: 1.8rem; font-weight: 900; color: #472825; margin-top: 10px;">₡@pedido.Total.ToString("N0")</div>
                        </div>
                    </summary>

                    @* Contenido del Ticket Desplegable *@
                    <div class="factura-box" style="padding: 30px; background: #fdfdfd; border-top: 2px dashed #fde4bc; font-family: 'Courier New', Courier, monospace;">
                        <div style="text-align: center; margin-bottom: 30px;">
                            <h2 style="color: #472825; font-weight: 900; margin-bottom: 5px; font-size: 1.2rem; font-family: sans-serif;">DETALLE DE FACTURACIÓN</h2>
                            <div style="height: 2px; width: 60px; background: #d3ab80; margin: 0 auto;"></div>
                        </div>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px;">
                            <thead>
                                <tr style="border-bottom: 2px solid #fde4bc; color: #96786f; font-size: 0.85rem; text-transform: uppercase; font-family: sans-serif;">
                                    <th style="text-align: left; padding: 10px;">Cant.</th>
                                    <th style="text-align: left; padding: 10px;">Descripción</th>
                                    <th style="text-align: right; padding: 10px;">Unitario</th>
                                    <th style="text-align: right; padding: 10px;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (pedido.Detalles != null)
                                {
                                    foreach (var detalle in pedido.Detalles)
                                    {
                                        <tr style="border-bottom: 1px solid #eee; color: #472825;">
                                            <td style="padding: 15px 10px; font-weight: bold;">@detalle.Cantidad</td>
                                            <td style="padding: 15px 10px; font-weight: 600;">@(detalle.Producto?.Nombre ?? "Producto")</td>
                                            <td style="padding: 15px 10px; text-align: right;">₡@detalle.PrecioHistorico.ToString("N0")</td>
                                            <td style="padding: 15px 10px; text-align: right; font-weight: 800;">₡@((detalle.PrecioHistorico * detalle.Cantidad).ToString("N0"))</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        @* Área de Totales *@
                        <div class="desglose-area" style="max-width: 420px; margin-left: auto; font-family: sans-serif;">
                            @{
                                // Ajuste: 1500 envío + 500 servicio = 2000 total de cargos fijos
                                decimal cargosFijos = 2000;
                                decimal subtotalProductos = pedido.Detalles?.Sum(d => d.PrecioHistorico * d.Cantidad) ?? 0;

                                // El Total ya incluye el descuento restado en la BD
                                // IVA se calcula sobre el pago real del cliente (Base imponible)
                                decimal baseImponible = (subtotalProductos + cargosFijos - pedido.MontoDescuento) / 1.13m;
                                decimal iva = (subtotalProductos + cargosFijos - pedido.MontoDescuento) - baseImponible;
                            }

                            <div style="display: flex; justify-content: space-between; margin-bottom: 8px; color: #96786f;">
                                <span>Subtotal Productos:</span>
                                <span>₡@subtotalProductos.ToString("N0")</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 8px; color: #96786f;">
                                <span>Cargos de Entrega y Servicio:</span>
                                <span>₡@cargosFijos.ToString("N0")</span>
                            </div>

                            @if (pedido.MontoDescuento > 0)
                            {
                                <div style="display: flex; justify-content: space-between; margin-bottom: 8px; color: #27ae60; font-weight: bold; border: 1px dashed #27ae60; padding: 5px; border-radius: 5px;">
                                    <span><i class="fa-solid fa-tag"></i> Descuento Cupón:</span>
                                    <span>-₡@pedido.MontoDescuento.ToString("N0")</span>
                                </div>
                            }

                            <div style="display: flex; justify-content: space-between; margin-bottom: 8px; color: #96786f; font-size: 0.8rem; font-style: italic;">
                                <span>Impuesto de Ventas (13% IVA):</span>
                                <span>₡@iva.ToString("N0")</span>
                            </div>

                            <div style="display: flex; justify-content: space-between; padding-top: 15px; border-top: 2px solid #472825; font-size: 1.6rem; font-weight: 900; color: #472825; margin-top: 10px;">
                                <span>MONTO TOTAL:</span>
                                <span>₡@pedido.Total.ToString("N0")</span>
                            </div>
                        </div>

                        @* Pie del Ticket *@
                        <div style="text-align: center; margin-top: 40px; border-top: 1px dashed #ccc; padding-top: 20px;">
                            <p style="color: #96786f; font-size: 0.85rem; margin: 0;">¡Gracias por preferir Rappi'Doz!</p>
                            <p style="font-family: monospace; font-weight: bold; color: #472825; margin: 8px 0 0 0; letter-spacing: 1px;">
                                AUTH-CODE: @pedido.Id-@pedido.FechaHora.Ticks.ToString().Substring(13)
                            </p>
                            <div style="margin-top: 15px;">
                                <i class="fa-solid fa-barcode" style="font-size: 2.5rem; color: #472825; opacity: 0.7;"></i>
                            </div>
                        </div>
                    </div>
                </details>
            }
        }
    </div>
</div>