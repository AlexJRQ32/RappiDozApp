@using RappiDozApp.Models
@model List<RappiDozApp.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito | Rappi'Doz";

    decimal subtotal = ViewBag.Subtotal ?? 0;
    decimal descuento = ViewBag.Descuento ?? 0;
    decimal envio = subtotal > 0 ? 2000 : 0;
    decimal total = (subtotal + envio) - descuento;

    var cuponesBilletera = ViewBag.CuponesApartados as List<RappiDozApp.Models.CuponApartado>;
    var ubicaciones = ViewBag.Ubicaciones as List<RappiDozApp.Models.UbicacionUsuario>;
    string codigoAplicado = ViewBag.CodigoAplicado as string;
}

<div class="super-contenedor-carrito">
    <input type="hidden" id="errorMsg" value="@TempData["MensajeError"]" />
    <input type="hidden" id="successMsg" value="@TempData["MensajeExito"]" />

    <div class="carrito-bordeado">

        <header class="carrito-header">
            <h2 class="carrito-title">
                <i class="fas fa-shopping-basket"></i> MI PEDIDO
            </h2>
            <a asp-controller="Home" asp-action="Index" class="carrito-back-link">
                <i class="fas fa-chevron-left"></i> SEGUIR COMPRANDO
            </a>
        </header>

        <div class="carrito-grid">

            <section>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="item-carrito">
                            <img src="/Productos/Imagen/@item.ProductoId" class="img-carrito" alt="@item.Nombre" loading="lazy">

                            <div class="item-main-info">
                                <h5 class="item-name">@item.Nombre</h5>
                                <span class="item-price">₡@item.Precio.ToString("N0")</span>
                            </div>

                            <div class="control-cantidad">
                                <form asp-controller="Carritos" asp-action="ActualizarCantidad" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                    <input type="hidden" name="accion" value="disminuir" />
                                    <button type="submit" class="btn-qty">−</button>
                                </form>
                                <span class="qty-number">@item.Cantidad</span>
                                <form asp-controller="Carritos" asp-action="ActualizarCantidad" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                    <input type="hidden" name="accion" value="aumentar" />
                                    <button type="submit" class="btn-qty">+</button>
                                </form>
                            </div>

                            <a asp-controller="Carritos" asp-action="Eliminar" asp-route-id="@item.ProductoId" class="item-remove-link">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="carrito-empty">
                        <p class="carrito-empty-text">Tu bolsa está actualmente vacía.</p>
                    </div>
                }
            </section>

            <aside>
                <div class="resumen-panel">

                    <div class="shipping-box">
                        <p class="section-label"><i class="fas fa-map-marker-alt section-icon"></i> Dirección de Envío</p>
                        <div class="ubicacion-row">
                            <select id="selectUbicacionPedido" name="UbicacionId" form="formCheckout" class="ubicacion-select">
                                <option value="">-- Elige una ubicación --</option>
                                @if (ubicaciones != null)
                                {
                                    foreach (var u in ubicaciones)
                                    {
                                        <option value="@u.IdUbicacion">@u.NombreUbicacion</option>
                                    }
                                }
                            </select>
                            <button type="button" class="ubicacion-delete-btn" onclick="borrarUbicacionSeleccionada()">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="ubicacion-extra-link-wrap">
                            <a asp-controller="Ubicaciones" asp-action="Index" class="agregar-otra-ubi">
                                <i class="fas fa-plus"></i> Gestionar direcciones
                            </a>
                        </div>
                    </div>

                    <div class="shipping-box">
                        <p class="section-label"><i class="fas fa-credit-card section-icon"></i> Método de Pago</p>
                        <select id="selectMetodoPago" name="MetodoPagoId" form="formCheckout" class="ubicacion-select">
                            <option value="1">Efectivo</option>
                            <option value="2">Tarjeta (Datáfono)</option>
                            <option value="3">SINPE Móvil</option>
                        </select>
                    </div>

                    <div class="carrito-cupones-section">
                        <p class="section-label"><i class="fas fa-ticket-alt section-icon"></i> Billetera de Cupones</p>

                        <div class="scroll-cupones">
                            @if (cuponesBilletera != null && cuponesBilletera.Any())
                            {
                                foreach (var c in cuponesBilletera)
                                {
                                    bool esActivo = (codigoAplicado == c.Codigo);
                                    if (esActivo) continue;

                                    <div class="card-cupon" onclick="aplicar('@c.Codigo')">
                                        <span><i class="fas fa-tag"></i> @c.Codigo</span>
                                        <b>@(c.EsPorcentaje? c.Descuento + "%" : "₡" + c.Descuento.ToString("N0"))</b>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="cupones-empty">No tienes beneficios disponibles.</p>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(codigoAplicado))
                        {
                            <div class="cupon-link-wrap">
                                <span class="badge-aplicado">
                                    <i class="fas fa-check-circle"></i> @codigoAplicado APLICADO
                                </span>
                                <br />
                                <a asp-controller="Cupones" asp-action="QuitarCupon" class="cupon-remove-link">
                                    [ELIMINAR CUPÓN]
                                </a>
                            </div>
                        }
                    </div>

                    <div class="resumen-detalle">
                        <div class="resumen-line">
                            <span>Subtotal</span>
                            <b>₡@subtotal.ToString("N0")</b>
                        </div>
                        <div class="resumen-line">
                            <span>Envío</span>
                            <b>₡@envio.ToString("N0")</b>
                        </div>
                        @if (descuento > 0)
                        {
                            <div class="resumen-discount txt-descuento-positivo">
                                <span>Descuento aplicado</span>
                                <b>-₡@descuento.ToString("N0")</b>
                            </div>
                        }
                    </div>

                    <div class="resumen-grand-total">
                        <span>TOTAL</span>
                        <span>₡@total.ToString("N0")</span>
                    </div>

                    <form id="formCheckout" asp-controller="Pedidos" asp-action="ConfirmarPedido" method="post" class="checkout-form">
                        <button type="submit" class="checkout-btn">
                            CONFIRMAR PEDIDO
                        </button>
                    </form>

                </div>
            </aside>
        </div>
    </div>
</div>

<form id="formCuponHidden" asp-controller="Cupones" asp-action="AplicarCupon" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="codigo" id="valCupon" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/Carritos/carrito.js" asp-append-version="true"></script>
}