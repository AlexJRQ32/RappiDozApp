@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - Rappi'Doz</title>
    <link rel="stylesheet" href="~/css/_StylesLogin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

   
    <div class="form">
        <h1>Recuperar Contraseña</h1>
        
        <p style="text-align: center; color: white; margin-bottom: 20px;">
            Ingresa tu correo electrónico para enviarte las instrucciones de restablecimiento.
        </p>

        <form asp-controller="Acceso" asp-action="OlvidastePassword" method="post">
            @Html.AntiForgeryToken()

            <section>
                <div class="container-translucid">
                    <input type="email" name="correo" placeholder="Correo electrónico" autofocus required>
                    <i class="fa-solid fa-envelope"></i>
                </div>
            </section>

            @if (ViewBag.Mensaje != null)
            {
                <p style="color: #8fce00; text-align: center; font-weight: bold;">@ViewBag.Mensaje</p>
            }
            @if (ViewBag.Error != null)
            {
                <p style="color: #ff4d4d; text-align: center; font-weight: bold;">@ViewBag.Error</p>
            }

            <section>
                <div class="container-translucid">
                    <button type="submit" id="button" style="width: 100%; border: none; background: transparent; color: white; cursor: pointer; font-size: 1.1rem;">
                        Enviar enlace
                    </button>
                </div>
            </section>

            <div class="register">
                <a asp-action="Login" id="register">Volver al Inicio de sesión</a>
            </div>
        </form>
    </div>
</body>
</html>